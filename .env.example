# ─── Database (Supabase) ─────────────────────────────
# Transaction pooler URL (port 6543) — used by the app
DATABASE_URL=postgresql://postgres.[project-ref]:Google@181@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
# Direct connection URL (port 5432) — used for migrations only
DIRECT_URL=postgresql://postgres:Google@181@db.[project-ref].supabase.co:5432/postgres

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Backend ─────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development

# ─── JWT / Auth ──────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY=7d
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6

# ─── External Challan Provider ───────────────────────
CHALLAN_PROVIDER_BASE_URL=https://api.invincibleocean.com
CHALLAN_PROVIDER_CLIENT_ID=your_client_id
CHALLAN_PROVIDER_SECRET_KEY=your_secret_key

# ─── Razorpay ────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret

# ─── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Rate Limiting ───────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=10
CHALLAN_SEARCH_THROTTLE_TTL=60
CHALLAN_SEARCH_THROTTLE_LIMIT=5
