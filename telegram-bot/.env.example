# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Optional overrides (all have defaults in config.py) ───────────────────────
POLLING_MODE=true
TELEGRAM_WEBHOOK_URL=

# If the scraper runs outside India, route eParivahan traffic through an
# Indian proxy to avoid upstream connection timeouts / blocking.
# EPARIVAHAN_PROXY_URL=http://user:pass@proxy.example.com:8080

SCRAPER_TIMEOUT=20
TOTAL_TIMEOUT=90
RETRY_DELAY=2
MAX_RETRIES=1

HEADLESS_BROWSER=true
BROWSER_SLOW_MO=100

DATABASE_PATH=./data/challan_bot.db
DATABASE_BACKUP_PATH=./backups/
SEARCH_RETENTION_DAYS=30

LOG_DIR=./logs
LOG_LEVEL=INFO

MAX_SEARCHES_PER_MINUTE=5
SEARCH_COOLDOWN=12

CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

HEALTH_CHECK_PORT=8080
