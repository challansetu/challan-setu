generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Admin Users ────────────────────────────────────
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(SUPPORT_AGENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  notes         AdminNote[]
  statusChanges UserStatusHistory[]
  auditLogs     AuditLog[]

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT_AGENT
}

// ─── Users ──────────────────────────────────────────
model User {
  id                String              @id @default(cuid())
  phone             String              @unique
  name              String?
  email             String?
  role              UserRole            @default(USER)
  isActive          Boolean             @default(true)
  lifecycleStatus   UserLifecycleStatus @default(NEW_USER)
  lastActiveAt      DateTime?
  consentAccepted   Boolean             @default(false)
  consentAcceptedAt DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  vehicles        Vehicle[]
  challanSearches ChallanSearch[]
  adminNotes      AdminNote[]
  statusHistory   UserStatusHistory[]
  auditLogs       AuditLog[]
  userChallans    UserChallan[]

  @@index([lifecycleStatus])
  @@index([lastActiveAt])
  @@index([createdAt])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

enum UserLifecycleStatus {
  NEW_USER
  ACTIVE
  PAYMENT_PENDING
  PAYMENT_FAILED
  COMPLETED
  CHURNED
  BLOCKED
}

// ─── Vehicles ───────────────────────────────────────
model Vehicle {
  id                      String   @id @default(cuid())
  userId                  String
  vehicleNumber           String
  normalizedVehicleNumber String?
  nickname                String?
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())

  user            User            @relation(fields: [userId], references: [id])
  challanSearches ChallanSearch[]

  @@unique([userId, vehicleNumber])
  @@index([vehicleNumber])
  @@index([normalizedVehicleNumber])
  @@map("vehicles")
}

// ─── Challan Searches ───────────────────────────────
model ChallanSearch {
  id                      String       @id @default(cuid())
  userId                  String
  vehicleId               String
  vehicleNumber           String
  normalizedVehicleNumber String?
  resultCount             Int          @default(0)
  rawResponse             Json?
  status                  SearchStatus @default(PENDING)
  errorMessage            String?
  apiProvider             String       @default("scraper")
  apiCost                 Int          @default(0)
  cachedResponseUsed      Boolean      @default(false)
  supportableFound        Int          @default(0)
  serviceable             Boolean?
  serviceableRegionsFound String[]     @default([])
  createdAt               DateTime     @default(now())

  user     User      @relation(fields: [userId], references: [id])
  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  challans Challan[]

  @@index([userId])
  @@index([vehicleNumber])
  @@index([normalizedVehicleNumber])
  @@index([createdAt])
  @@map("challan_searches")
}

enum SearchStatus {
  PENDING
  SUCCESS
  FAILED
  NO_DATA
}

// ─── Challans ───────────────────────────────────────
model Challan {
  id                      String           @id @default(cuid())
  searchId                String
  challanNo               String
  vehicleNumber           String
  rcNo                    String?
  state                   String?
  challanDate             DateTime?
  location                String?
  amount                  Float
  status                  ChallanStatus
  receiptNo               String?
  challanSource           String?
  courtStatusDesc         String?
  courtName               String?
  normalizedVehicleNumber String?
  city                    String?
  authority               String?
  isSupported             Boolean?
  supportedRegion         SupportedRegion?
  unsupportedReason       String?
  matchedBy               String?
  lastSyncedAt            DateTime?
  rawData                 Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  search   ChallanSearch    @relation(fields: [searchId], references: [id])
  offences ChallanOffence[]

  @@unique([searchId, challanNo])
  @@index([vehicleNumber])
  @@index([challanNo])
  @@index([isSupported, status])
  @@index([normalizedVehicleNumber])
  @@map("challans")
}

enum ChallanStatus {
  PAID
  UNPAID
  PARTIAL
  UNKNOWN
}

enum SupportedRegion {
  DELHI
  GURGAON
  NOIDA
  GHAZIABAD
}

// ─── Challan Offences ───────────────────────────────
model ChallanOffence {
  id        String @id @default(cuid())
  challanId String
  offence   String
  penalty   Float?

  challan Challan @relation(fields: [challanId], references: [id], onDelete: Cascade)

  @@map("challan_offences")
}

// ─── Lead Challans (per-challan CRM tracking) ───────
model LeadChallan {
  id            String   @id @default(cuid())
  leadId        String
  challanNumber String
  realAmount    Float?
  amount        Float
  location      String
  settledAmount Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_challans")
}

// ─── Optional Lead model (keep if needed) ─────────────
model Lead {
  id               String   @id @default(cuid())
  fullName         String
  mobileNumber     String
  vehicleNumber    String
  consentAccepted  Boolean
  consentTimestamp DateTime
  source           String   @default("homepage")
  city             String?
  leadStatus       String   @default("new")

  // CRM fields
  crmStatus      String @default("new") // new | follow_up | converted | dead
  paymentStatus  String @default("pending") // pending | payment_done
  challanSettled String @default("no") // yes | no | initiated
  totalChallan   Int?
  paidAmount     Int?
  settledAmount  Int?
  discountGiven  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadChallans LeadChallan[]

  @@index([mobileNumber])
  @@index([vehicleNumber])
  @@index([city])
  @@index([leadStatus])
  @@index([crmStatus])
  @@index([source])
  @@index([createdAt])
  @@map("leads")
}

// ─── Admin Notes ────────────────────────────────────
model AdminNote {
  id        String   @id @default(cuid())
  userId    String
  adminId   String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([userId])
  @@map("admin_notes")
}

// ─── User Status History ─────────────────────────────
model UserStatusHistory {
  id        String              @id @default(cuid())
  userId    String
  oldStatus UserLifecycleStatus
  newStatus UserLifecycleStatus
  changedBy String?
  reason    String?
  createdAt DateTime            @default(now())

  user  User       @relation(fields: [userId], references: [id])
  admin AdminUser? @relation(fields: [changedBy], references: [id])

  @@index([userId])
  @@map("user_status_history")
}

// ─── Audit Logs ──────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id])
  user  User?      @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([adminId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── User Challans (admin CRM tracking) ─────────────
model UserChallan {
  id            String   @id @default(cuid())
  userId        String
  challanNumber String
  amount        Float
  location      String
  settledAmount Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_challans")
}

// ─── QR Scan Tracking ────────────────────────────────
model QrScan {
  id        String   @id @default(cuid())
  source    String
  ip        String?
  userAgent String?
  referrer  String?
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([source])
  @@index([createdAt])
  @@index([source, createdAt])
  @@map("qr_scans")
}

// ─── Discount Rules ──────────────────────────────────
enum DiscountType {
  PERCENTAGE
  FIXED
}

model DiscountRule {
  id             String       @id @default(cuid())
  name           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Float
  maxDiscount    Float?
  minOrderAmount Float        @default(0)
  isActive       Boolean      @default(true)
  validFrom      DateTime
  validUntil     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([isActive])
  @@map("discount_rules")
}
